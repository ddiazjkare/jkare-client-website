# OAuth Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
FACEBOOK_CLIENT_ID=your_facebook_client_id_here
FACEBOOK_CLIENT_SECRET=your_facebook_client_secret_here
TWITTER_CLIENT_ID=your_twitter_client_id_here
TWITTER_CLIENT_SECRET=your_twitter_client_secret_here

# API Configuration
# For local development, use: http://localhost:3002/api
# For production, use: https://your-domain.com/api
NEXT_PUBLIC_API_URL=http://localhost:3002/api

# NextAuth Configuration
# For local development, use: http://localhost:3002
# For production, use: https://your-domain.com
NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=your_nextauth_secret_here

# Security
SECRET_KEY=your_secret_key_here

# Email Configuration
EMAIL_ID=your_email@example.com
EMAIL_PASS=your_email_app_password_here

# Google Services
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
SEARCH_ENGINE_ID=your_search_engine_id_here

# Stripe Configuration
STRIPE_SECRET_KEY=your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# AWS Configuration
AWS_REGION=your_aws_region
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# Other
CHECKOUT_RES_URL=your_checkout_callback_url

# Shippo (optional)
#SHIPPO_API_KEY=your_shippo_api_key_here
